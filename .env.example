# ==============================
# Discord Bot Configuration
# ==============================

# Token của bot Discord (lấy từ Discord Developer Portal)
DISCORD_TOKEN=

# Client ID của bot (lấy từ General Information)
CLIENT_ID=

# Guild ID (ID server Discord chính)
GUILD_ID=

# ==============================
# Flarum API Configuration
# ==============================

# Đường dẫn API Flarum (không có dấu / ở cuối)
FLARUM_API=https://example.com/api

# Đường dẫn gốc Flarum (để tạo link bài viết)
FLARUM_BASE=https://example.com

# Token API Flarum (nếu forum yêu cầu xác thực, để trống nếu public)
FLARUM_API_TOKEN=

# ==============================
# Bot Settings
# ==============================

# Khoảng thời gian polling (ms) - mặc định 30 giây
POLL_INTERVAL=30000

# Ngôn ngữ mặc định
DEFAULT_LANGUAGE=vi

# Số ký tự preview nội dung bài viết
CONTENT_PREVIEW_LENGTH=300

# ==============================
# Auto Approve Settings
# ==============================

# Danh sách username Flarum được tự động duyệt (phân cách bằng dấu phẩy)
AUTO_APPROVE_AUTHORS=

# Danh sách tag slug được tự động duyệt (phân cách bằng dấu phẩy)
AUTO_APPROVE_TAGS=

# Danh sách Discord Role ID được phép duyệt bài (phân cách bằng dấu phẩy)
ADMIN_ROLE_IDS=

# ==============================
# Advanced Settings
# ==============================

# Số lần retry khi API lỗi
API_RETRY_COUNT=3

# Thời gian chờ API timeout (ms)
API_TIMEOUT=10000

# Cooldown giữa các lần xử lý bài viết (ms)
QUEUE_COOLDOWN=2000

# Tên forum hiển thị trên footer embed
FORUM_NAME=Flarum Forum
